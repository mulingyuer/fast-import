{
	"name": "fast-import",
	"displayName": "fast-import",
	"version": "0.1.0",
	"description": "%extension.description%",
	"categories": [
		"Other"
	],
	"bugs": {
		"url": "https://github.com/mulingyuer/fast-import/issues"
	},
	"license": "SEE LICENSE IN LICENSE",
	"repository": {
		"type": "git",
		"url": "https://github.com/mulingyuer/fast-import"
	},
	"publisher": "mulingyuer",
	"main": "./dist/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"build": "vsce package",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "20.19.37",
		"@types/vscode": "^1.75.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^9.39.4",
		"glob": "^13.0.6",
		"mocha": "^11.3.0",
		"oxfmt": "^0.41.0",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2"
	},
	"l10n": "./l10n",
	"contributes": {
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"fast-import.enableMoveToBraces": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.enableMoveToBraces.description%"
				},
				"fast-import.enableOutToBraces": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.enableOutToBraces.description%"
				},
				"fast-import.enableTransformToDestructuring": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.enableTransformToDestructuring.description%"
				}
			}
		},
		"commands": [
			{
				"command": "fast-import.moveToBraces",
				"title": "%command.moveToBraces.title%"
			},
			{
				"command": "fast-import.outToBraces",
				"title": "%command.outToBraces.title%"
			}
		],
		"keybindings": [
			{
				"command": "fast-import.moveToBraces",
				"key": "alt+i",
				"mac": "alt+i",
				"when": "editorTextFocus && config.fast-import.enableMoveToBraces"
			},
			{
				"command": "fast-import.outToBraces",
				"key": "alt+o",
				"mac": "alt+o",
				"when": "editorTextFocus && config.fast-import.enableOutToBraces"
			}
		]
	},
	"activationEvents": [
		"onLanguage"
	],
	"icon": "public/icon.png",
	"galleryBanner": {
		"color": "#3e3838",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.75.0"
	}
}
